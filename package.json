{
  "name": "jub-rn",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 3000",
    "start:clear": "expo start --clear --port 3000",
    "android": "expo start --android --port 3000",
    "ios": "expo start --ios --port 3000",
    "web": "expo start --web --port 3000",
    "build:apk": "npx eas-cli@latest build -p android --profile preview",
    "build:apk:dev": "npx eas-cli@latest build -p android --profile development",
    "build:apk:local": "cd android && gradlew.bat assembleRelease",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.5",
    "axios": "^1.15.2",
    "expo": "~55.0.17",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.28",
    "expo-linking": "~55.0.14",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.74.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2"
  }
}
